# Generated by Chef
<% @servers.each.with_index(1) do |server, index| -%>
$ActionQueueType LinkedList # use asynchronous processing
$ActionQueueFileName srvrfwd<%= index %> # set file name, also enables disk mode
$ActionResumeRetryCount -1 # infinite retries on insert failure
$ActionQueueSaveOnShutdown on # save in-memory data if rsyslog shuts down
$ActionQueueMaxDiskSpace <%= @action_queue_max_disk_space %> # Don't use more than this much space for the queue
<% if @enable_tls && @tls_ca_file -%>
$DefaultNetstreamDriverCAFile <%= @tls_ca_file %>
<%   if @tls_certificate_file -%>
$DefaultNetstreamDriverCertFile <%= @tls_certificate_file %>
<%   end -%>
<%   if @tls_key_file -%>
$DefaultNetstreamDriverKeyFile <%= @tls_key_file %>
<%   end -%>

$DefaultNetstreamDriver gtls
$ActionSendStreamDriverMode 1
$ActionSendStreamDriverAuthMode <%= @tls_auth_mode %>
<% if @tls_permitted_peer -%>
$ActionSendStreamDriverPermittedPeer <%= @tls_permitted_peer %>
<% end -%>
<% end -%>

<%   case server['protocol'] -%>
<%     when "tcp" -%>
<%=      server['logs'] ? server['logs'] : @logs_to_forward %> @@<%= server['server']  %>:<%= server['port'] ? server['port'] : @port %><%= server['remote_template'] ? ';' + server['remote_template'] : nil %>
<%     when "udp" -%>
<%=      server['logs'] ? server['logs'] : @logs_to_forward %> @<%= server['server']  %>:<%= server['port'] ? server['port'] : @port %><%= server['remote_template'] ? ';' + server['remote_template'] : nil %>
<%     else -%>
<%=      server['logs'] ? server['logs'] : @logs_to_forward %><%= @protocol == "tcp" ? " @@" : " @" %><%= server['server']  %>:<%= server['port'] ? server['port'] : @port %><%= server['remote_template'] ? ';' + server['remote_template'] : nil %>
<%   end -%>

<% end -%>
