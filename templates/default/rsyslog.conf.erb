# Config generated by Chef - manual edits will be overwritten
#
#  /etc/rsyslog.conf  Configuration file for rsyslog.
#
#     For more information see
#     /usr/share/doc/rsyslog-doc/html/rsyslog_conf.html
#
#  Default logging rules can be found in /etc/rsyslog.d/50-default.conf
#
# Set hostname
#
<% if @local_host_name -%>
$LocalHostName <%= @local_host_name %>
<% end %>
#
# Set max message size
#
<% if @max_message_size -%>
$MaxMessageSize <%= @max_message_size %>
<% end %>

#
# Preserve FQDN
#
$PreserveFQDN <%= @preserve_fqdn %>

#################
#### MODULES ####
#################

<% if @modules && !@modules.empty? %>
  <% [*@modules].each do |mod| %>
    <% params = []%>
    <% @module_directives.fetch(mod, {}).each {|k, v| params.push("#{k}=\"#{v}\"")} %>
module(load="<%= mod %>" <%= params.join(' ') -%>) 
  <%- end -%>
<% end %>

<% if @server -%>
  <% if @enable_tls && @tls_ca_file && @tls_key_file && @tls_certificate_file -%>
$DefaultNetstreamDriver <%= @tls_driver %>
$DefaultNetstreamDriverCAFile <%= @tls_ca_file %>
$DefaultNetstreamDriverCertFile <%= @tls_certificate_file %>
$DefaultNetstreamDriverKeyFile <%= @tls_key_file %>

module(load="imtcp"
  MaxSessions="<%= @tcp_max_sessions || 200 %>"
  StreamDriver.Mode="1"
  StreamDriver.AuthMode="<%= @tls_auth_mode || 'anon' %>")
input(type="imtcp" Port="<%= @port %>")

# Provide <%= @protocol.upcase %> log reception
  <% else -%>
<% if @protocol =~ /tcp/ %>
module(load="imtcp"
  MaxSessions="<%= @tcp_max_sessions || 200 %>")
input(type="imtcp" Port="<%= @port %>")
<% end -%>
<% if @protocol =~ /udp/ %>
module(load="imudp")
input(type="imudp"
  Address="<%= @bind %>"
  Port="<%= @port %>")
<% end -%>
  <% end -%>
<% end -%>

###########################
#### GLOBAL DIRECTIVES ####
###########################

<% if @default_file_template -%>
#
# Default log format template
#
$ActionFileDefaultTemplate <%= @default_file_template %>
<% elsif !@high_precision_timestamps -%>
#
# Use traditional timestamp format.
# To enable high precision timestamps, comment out the following line.
#
$ActionFileDefaultTemplate RSYSLOG_TraditionalFileFormat
<% end -%>

<% if @templates && !@templates.empty? -%>
<% [*@templates].each do |template| %>
#
# Additional Log templates
#
$Template <%= template %>
<% end %>
<% end %>
# Filter duplicated messages
$RepeatedMsgReduction <%= @repeated_msg_reduction %>

#
# Set temporary directory to buffer syslog queue
#
$WorkDirectory <%= @working_dir %>

#
# Set the default permissions for all log files.
#
$Umask <%= @umask %>
$FileOwner <%= @user %>
$FileGroup <%= @group %>
$FileCreateMode <%= @file_create_mode %>
$DirOwner <%= @dir_owner %>
$DirGroup <%= @dir_group %>
$DirCreateMode <%= @dir_create_mode %>

<% if @priv_seperation %>
$PrivDropToUser <%= @priv_user || @user %>
$PrivDropToGroup <%= @priv_group || @group %>
<% end %>
<% unless @rate_limit_interval.nil? %>
#
# Set the amount of time that is being measured for rate limiting
#
$SystemLogRateLimitInterval <%= @rate_limit_interval %>
<% end %>
<% unless @rate_limit_burst.nil? %>
#
# Set the amount of messages, that have to occur in the time limit of
#   SystemLogRateLimitInterval, to trigger rate limiting
#
$SystemLogRateLimitBurst <%= @rate_limit_burst %>
<% end %>

#
# Set other directives
#
<% @additional_directives.each_pair do |k,v| %>
$<%= k %> <%= v %>
<% end %>

#
# Include all config files in <%= @config_prefix %>/rsyslog.d/
#
$IncludeConfig <%= @config_prefix %>/rsyslog.d/*.conf
